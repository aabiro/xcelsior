# Stripe LIVE production credentials — copy into .env on prod host.
# Dashboard: https://dashboard.stripe.com/apikeys
# Webhooks: https://dashboard.stripe.com/webhooks → https://xcelsior.ca/api/billing/stripe/webhook

XCELSIOR_STRIPE_MODE=live
XCELSIOR_STRIPE_SECRET_KEY=
XCELSIOR_STRIPE_WEBHOOK_SECRET=
# Optional restricted-scope key (rk_live_…) for read-only analytics — not used for Connect charges
XCELSIOR_STRIPE_RESTRICTED_KEY=

# Keep sandbox keys for local/CI test mode
XCELSIOR_STRIPE_SANDBOX_SECRET_KEY=
XCELSIOR_STRIPE_SANDBOX_WEBHOOK_SECRET=

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_SANDBOX_PUBLISHABLE_KEY=