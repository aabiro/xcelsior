{
  "name": "@xcelsior-gpu/mcp",
  "version": "0.1.0",
  "description": "Stdio MCP client for the Xcelsior GPU platform — use with npx @xcelsior-gpu/mcp",
  "type": "module",
  "bin": {
    "xcelsior-mcp": "./bin/xcelsior-mcp.js"
  },
  "files": ["bin", "dist"],
  "engines": { "node": ">=18" },
  "scripts": {
    "build": "cd ../mcp && npm ci && npm run build && rm -rf ../mcp-cli/dist && cp -r dist ../mcp-cli/dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.0",
    "zod": "^3.24.0"
  },
  "keywords": ["mcp", "gpu", "xcelsior", "model-context-protocol", "ai-agents"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xcelsior/xcelsior.git",
    "directory": "mcp-cli"
  }
}