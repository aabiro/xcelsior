# PayPal LIVE production credentials (wallet deposits + marketplace payouts).
# Copy values into .env on the production host — never commit live secrets.
#
# Developer Dashboard → Apps & Credentials → Live → REST API app
# Webhooks → Live → create listener for https://xcelsior.ca/api/billing/paypal/webhook

PAYPAL_MODE=live
NEXT_PUBLIC_PAYPAL_MODE=live
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Platform Complete Payments (marketplace seller onboarding)
PAYPAL_PARTNER_ATTRIBUTION_ID=
PAYPAL_PLATFORM_MERCHANT_ID=
PAYPAL_PARTNER_MERCHANT_ID=
PAYPAL_PLATFORM_PAYEE_EMAIL=

# Manual login for live dashboard verification (not read by app code)
PAYPAL_LIVE_PLATFORM_EMAIL=
PAYPAL_LIVE_PLATFORM_PASSWORD=