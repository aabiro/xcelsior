# ═══════════════════════════════════════════════════════════════════════
# Xcelsior v2.1.0 — Environment Variables
# Copy to .env and fill in your values.
# Variables marked [REQUIRED] must be set for production.
# ═══════════════════════════════════════════════════════════════════════

# ── Runtime Environment ───────────────────────────────────────────────
# dev = no token required, relaxed validation
# test = token required, test DB
# production = full security, rate limiting
XCELSIOR_ENV=dev

# ── Base URL ──────────────────────────────────────────────────────────
# Public URL for OAuth callbacks, emails, and external links.
XCELSIOR_BASE_URL=https://xcelsior.ca
XCELSIOR_SSH_HOST=connect.xcelsior.ca
# Web Push (generate your own VAPID keypair for each environment)
XCELSIOR_WEB_PUSH_VAPID_PUBLIC_KEY=
XCELSIOR_WEB_PUSH_VAPID_PRIVATE_KEY=
XCELSIOR_WEB_PUSH_VAPID_SUBJECT=mailto:hello@xcelsior.ca
XCELSIOR_WEB_PUSH_STALE_AFTER_DAYS=30
XCELSIOR_WEB_PUSH_REVOKED_RETENTION_DAYS=30
XCELSIOR_NOTIFICATION_RETENTION_DAYS=30
# Default region for CLI and API (e.g. ca-east, us-west)
XCELSIOR_REGION=

# ── API Authentication [REQUIRED in production] ──────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
XCELSIOR_API_TOKEN=

# ── Persistent Auth ──────────────────────────────────────────────────
# SQLite-backed user/session/notification store. Set "false" for in-memory only.
XCELSIOR_PERSISTENT_AUTH=true

# ── Rate Limiting ─────────────────────────────────────────────────────
XCELSIOR_RATE_LIMIT_REQUESTS=120
XCELSIOR_RATE_LIMIT_WINDOW_SEC=60
# WebSocket connection rate limit (per IP)
XCELSIOR_WS_CONNECT_RATE_LIMIT_REQUESTS=60
XCELSIOR_WS_CONNECT_RATE_LIMIT_WINDOW_SEC=60
XCELSIOR_WS_TICKET_TTL_SEC=60

# ── Database Backend ──────────────────────────────────────────────────
# sqlite = local SQLite only (dev/single-node)
# postgres = PostgreSQL only (production)
# dual = dual-write to both (recommended for production migration)
XCELSIOR_DB_BACKEND=sqlite
XCELSIOR_DB_PATH=./xcelsior.db

# ── PostgreSQL [REQUIRED for production] ──────────────────────────────
XCELSIOR_POSTGRES_DSN=postgresql://xcelsior:change-me@localhost:5432/xcelsior
XCELSIOR_POSTGRES_DB=xcelsior
XCELSIOR_POSTGRES_HOST=localhost
XCELSIOR_POSTGRES_PORT=5432
XCELSIOR_POSTGRES_USER=xcelsior
XCELSIOR_POSTGRES_PASSWORD=change-me
XCELSIOR_PG_POOL_SIZE=20
XCELSIOR_PG_MAX_OVERFLOW=10
# Legacy DSN override (used in db.py; falls back to XCELSIOR_POSTGRES_DSN)
XCELSIOR_PG_DSN=
# Test database DSN (used by pytest)
XCELSIOR_TEST_POSTGRES_DSN=
# Alembic migration DSN override (falls back to XCELSIOR_POSTGRES_DSN)
DATABASE_URL=

# When DB_BACKEND=dual, which backend to read from:
XCELSIOR_DUAL_READ_FROM=sqlite

# ── Data Persistence — SQLite DB Paths ────────────────────────────────
# In Docker these are set to /data/* automatically via docker-compose.yml.
# Only override if running outside Docker or need a custom location.
XCELSIOR_AUTH_DB_PATH=data/auth.db
XCELSIOR_BILLING_DB_PATH=xcelsior_billing.db
XCELSIOR_REPUTATION_DB_PATH=xcelsior_reputation.db
XCELSIOR_INFERENCE_DB_PATH=data/inference.db
XCELSIOR_CHAT_DB_PATH=data/chat.db
XCELSIOR_TRANSPARENCY_DB_PATH=xcelsior_transparency.db
XCELSIOR_SLA_DB=xcelsior_sla.db
XCELSIOR_BTC_DB=xcelsior_btc.db
XCELSIOR_STRIPE_DB=xcelsior_stripe.db
XCELSIOR_PRIVACY_DB_PATH=xcelsior_privacy.db

# ── Data Persistence — JSON / Log Paths ───────────────────────────────
XCELSIOR_HOSTS_FILE=hosts.json
XCELSIOR_JOBS_FILE=jobs.json
XCELSIOR_LOG_FILE=xcelsior.log
XCELSIOR_BILLING_FILE=billing.json
XCELSIOR_MARKETPLACE_FILE=marketplace.json
XCELSIOR_AUTOSCALE_FILE=autoscale_pool.json
XCELSIOR_SPOT_PRICES_FILE=spot_prices.json
XCELSIOR_COMPUTE_SCORES_FILE=compute_scores.json
XCELSIOR_SLURM_MAP=data/slurm_jobs.json

# ── OAuth 2.0 Authorization Server ───────────────────────────────────
# Internal OAuth server for Authorization Code+PKCE, Device Flow, Client Credentials.
# Token TTLs (seconds)
XCELSIOR_OAUTH_ACCESS_TTL_SEC=900
XCELSIOR_OAUTH_REFRESH_TTL_SEC=2592000
XCELSIOR_OAUTH_CODE_TTL_SEC=300
XCELSIOR_OAUTH_DEVICE_TTL_SEC=900
XCELSIOR_OAUTH_DEVICE_INTERVAL_SEC=5
XCELSIOR_OAUTH_CLIENT_CREDENTIALS_TTL_SEC=900
XCELSIOR_OAUTH_ACCESS_TOKEN_PREFIX=xoa_
# JWT signing for client_credentials tokens.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
XCELSIOR_OAUTH_JWT_SECRET=
# Multi-key rotation (JSON). Overrides JWT_SECRET when set.
XCELSIOR_OAUTH_JWT_KEYS_JSON=
XCELSIOR_OAUTH_ACTIVE_KID=default
# Issuer / audience claims
XCELSIOR_OAUTH_ISSUER=
XCELSIOR_OAUTH_AUDIENCE=xcelsior-api
# Auth cache backend (redis in production, memory in test)
XCELSIOR_AUTH_CACHE_BACKEND=redis
XCELSIOR_AUTH_REDIS_URL=redis://localhost:6379/0
XCELSIOR_AUTH_CACHE_PREFIX=xcelsior:oauth
# Optional API-key sunset date shown in deprecation messaging (YYYY-MM-DD).
XCELSIOR_API_KEY_SUNSET_DATE=2026-07-07

# ── OAuth Providers (Third-Party) ────────────────────────────────────
# Register apps at each provider's developer console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
HUGGINGFACE_CLIENT_ID=
HUGGINGFACE_CLIENT_SECRET=

# ── Worker Agent [REQUIRED on GPU hosts] ──────────────────────────────
XCELSIOR_HOST_ID=
XCELSIOR_SCHEDULER_URL=http://localhost:8000
XCELSIOR_API_URL=http://localhost:8000
XCELSIOR_COST_PER_HOUR=0.50
XCELSIOR_HEARTBEAT_INTERVAL=10
XCELSIOR_POLL_INTERVAL=5
XCELSIOR_TELEMETRY_INTERVAL=5
XCELSIOR_MAX_FAILURES=30
# Worker OAuth machine-client auth. API keys remain supported too.
XCELSIOR_OAUTH_CLIENT_ID=
XCELSIOR_OAUTH_CLIENT_SECRET=
XCELSIOR_OAUTH_SCOPE=api
XCELSIOR_OAUTH_TOKEN_URL=

# ── Container Security ───────────────────────────────────────────────
# Prefer gVisor (runsc) runtime for supported GPUs
XCELSIOR_PREFER_GVISOR=true

# ── Host Tools Bind-Mount (P2.1 — instant interactive instance boot) ──
# Directory on the GPU host containing pre-staged binaries (rsync, git,
# curl, jq, htop, less, ca-certificates) that get bind-mounted read-only
# into every interactive container at /opt/xcelsior/bin. Populated by
# scripts/install.sh on host setup; skipped silently if absent.
XCELSIOR_TOOLS_DIR=/var/lib/xcelsior/tools

# Docker image cache limits (GB) on GPU workers
XCELSIOR_IMAGE_CACHE_MAX_GB=50
XCELSIOR_IMAGE_CACHE_EVICT_LOW_GB=40

# ── Mining Detection Thresholds ───────────────────────────────────────
XCELSIOR_MINING_GPU_UTIL=95
XCELSIOR_MINING_PCIE_TX_MB=5
XCELSIOR_MINING_DURATION_SEC=300
XCELSIOR_MINING_CHECK_INTERVAL=60

# ── Headscale / Tailscale Mesh ────────────────────────────────────────
XCELSIOR_TAILSCALE_ENABLED=false
XCELSIOR_TAILSCALE_AUTHKEY=
XCELSIOR_HEADSCALE_URL=

# ── SSH Key Management ───────────────────────────────────────────────
XCELSIOR_SSH_KEY_PATH=~/.ssh/xcelsior
XCELSIOR_SSH_USER=xcelsior

# ── NFS Shared Storage ───────────────────────────────────────────────
# General NFS mount (for shared data, models, etc.)
XCELSIOR_NFS_PATH=
XCELSIOR_NFS_MOUNT=/mnt/xcelsior-nfs

# ── NFS Volume Storage (Persistent Volumes) ─────────────────────────
# Mesh IP GPU workers mount (prod: 100.64.0.1 VPS pixelenhance-labs).
XCELSIOR_NFS_SERVER=
# SSH target for API provision/destroy — 127.0.0.1 when NFS is colocated on VPS.
XCELSIOR_NFS_SSH_HOST=
XCELSIOR_NFS_SSH_USER=
# LUKS on colocated Docker: SSH loopback to host (dm_mod unavailable in container)
XCELSIOR_NFS_LUKS_SSH_HOST=127.0.0.1
XCELSIOR_NFS_LUKS_SSH_USER=
# Optional SSH command wrapper (legacy Mac appliance only — leave empty on VPS)
XCELSIOR_NFS_SSH_CMD_WRAP=
# Export base path where volume directories are created (must match NFS export):
# VPS: /exports/volumes
# Smoke/ops: SSH to NFS host for marker writes and disk checks (user@mesh-ip)
NFS_SSH_HOST=linuxuser@100.64.0.1
WORKER_MOUNT_HOST=
WORKER_SSH_USER=aaryn
XCELSIOR_NFS_EXPORT_BASE=/exports/volumes
# Production: set true so /readyz fails when NFS is unreachable (see docs/VOLUMES_RUNBOOK.md)
XCELSIOR_NFS_REQUIRED=false
# Override default NFS mount options (hard,timeo=600,retrans=3,... — see volumes.NFS_MOUNT_OPTS):
XCELSIOR_NFS_MOUNT_OPTS=
# Max total storage across all volumes (GB):
XCELSIOR_MAX_TOTAL_STORAGE_GB=100
# Max single volume size (GB):
XCELSIOR_MAX_VOLUME_GB=2000
# Max volume count per billing owner (abuse guard, default 50):
XCELSIOR_MAX_VOLUMES_PER_OWNER=50
# Hot-attach API poll timeout in seconds (default 45):
XCELSIOR_HOT_MOUNT_TIMEOUT_SEC=45

# ── Volume Encryption (LUKS2) ────────────────────────────────────────
# Fernet key for encrypting LUKS volume keys at rest in the database.
# [REQUIRED in production] — volumes cannot be created/reopened without this.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
XCELSIOR_SECRETS_KEY=
# Worker-agent paths for ephemeral encrypted workspaces on GPU hosts:
XCELSIOR_VOLUME_DIR=/mnt/xcelsior/volumes
XCELSIOR_VOLUME_KEY_DIR=/etc/xcelsior/volume-keys

# ── Canadian Billing (CAD) ───────────────────────────────────────────
XCELSIOR_CAD_USD_RATE=0.73
XCELSIOR_PLATFORM_CUT=0.15
XCELSIOR_CANADA_ONLY=false

# ── Spot Pricing ─────────────────────────────────────────────────────
# Global kill switch for new spot launches (running spot jobs are not mass-killed).
XCELSIOR_SPOT_ENABLED=true
XCELSIOR_SPOT_SENSITIVITY=0.5
XCELSIOR_SPOT_THRESHOLD=0.8
XCELSIOR_SPOT_UPDATE_INTERVAL=600
XCELSIOR_PREEMPTION_GRACE_SEC=30

# ── Inference ─────────────────────────────────────────────────────────
XCELSIOR_INFERENCE_TTL=86400

# ── NVML Telemetry ───────────────────────────────────────────────────
XCELSIOR_THERMAL_HISTORY_SIZE=60

# ── Alerts: Email (SMTP) ─────────────────────────────────────────────
# Used for team invitation emails and admin alerts.
XCELSIOR_SMTP_HOST=
XCELSIOR_SMTP_PORT=587
XCELSIOR_SMTP_USER=
XCELSIOR_SMTP_PASS=
XCELSIOR_EMAIL_FROM=
XCELSIOR_EMAIL_TO=alerts@xcelsior.ca

# ── Alerts: Telegram ─────────────────────────────────────────────────
XCELSIOR_TG_TOKEN=
XCELSIOR_TG_CHAT_ID=

# ── Docker Image Builder ─────────────────────────────────────────────
XCELSIOR_REGISTRY=

# ── Auto-Scaling ─────────────────────────────────────────────────────
XCELSIOR_AUTOSCALE=false
XCELSIOR_AUTOSCALE_MAX=20
XCELSIOR_AUTOSCALE_PROVIDER=

# ── Artifact Storage — Primary (B2 / S3-compatible) ──────────────────
XCELSIOR_STORAGE_BACKEND=local
XCELSIOR_STORAGE_ENDPOINT_URL=
XCELSIOR_STORAGE_BUCKET=
XCELSIOR_STORAGE_REGION=
XCELSIOR_STORAGE_ACCESS_KEY_ID=
XCELSIOR_STORAGE_SECRET_ACCESS_KEY=
XCELSIOR_STORAGE_PRESIGN_EXPIRY=3600
XCELSIOR_STORAGE_MAX_UPLOAD_MB=500
XCELSIOR_STORAGE_RESIDENCY=CA

# ── Artifact Storage — Edge Cache (R2 / CDN) ─────────────────────────
XCELSIOR_CACHE_ENDPOINT_URL=
XCELSIOR_CACHE_BACKEND=local
XCELSIOR_CACHE_BUCKET=
XCELSIOR_CACHE_REGION=
XCELSIOR_CACHE_ACCESS_KEY_ID=
XCELSIOR_CACHE_SECRET_ACCESS_KEY=
XCELSIOR_CACHE_RESIDENCY=CA

# ── Stripe Connect (Provider Payouts) ────────────────────────────────
# Required for provider onboarding and marketplace payouts.
# Get keys at https://dashboard.stripe.com/apikeys
# Set XCELSIOR_STRIPE_MODE=sandbox for test keys, live for production.
# Live template: .env.stripe-live.example
XCELSIOR_STRIPE_MODE=sandbox
XCELSIOR_STRIPE_SECRET_KEY=
XCELSIOR_STRIPE_SANDBOX_SECRET_KEY=
XCELSIOR_STRIPE_WEBHOOK_SECRET=
XCELSIOR_STRIPE_SANDBOX_WEBHOOK_SECRET=
# Snapshot Connect destination secret → /api/providers/webhook (tried alongside
# XCELSIOR_STRIPE_WEBHOOK_SECRET so multiple destinations to one endpoint verify).
XCELSIOR_STRIPE_CONNECT_WEBHOOK_SECRET=
# Thin/v2 Connect destination secret → /api/connect/webhooks.
XCELSIOR_STRIPE_THIN_WEBHOOK_SECRET=
XCELSIOR_STRIPE_RESTRICTED_KEY=
XCELSIOR_PLATFORM_FEE_CENTS=200
# Default country (ISO 3166-1 alpha-2) for new connected accounts.
XCELSIOR_CONNECT_COUNTRY=ca

# ── PayPal ──────────────────────────────────────────────────────────
# Fully integrated in routes/billing.py + deposit-modal.tsx (create-order → popup → capture).
# Sandbox test credentials: .env.paypal-sandbox.example
# Live production credentials: .env.paypal-live.example (copy into .env on prod host)
#
# Platform Complete Payments (marketplace) — use your platform REST app credentials.
# Do NOT sign up for a new business at paypal.com for sandbox; use Developer Dashboard
# → Sandbox → Accounts (sb-*@business.example.com / sb-*@personal.example.com).
#
PAYPAL_MODE=sandbox
NEXT_PUBLIC_PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_PARTNER_ATTRIBUTION_ID=
PAYPAL_PLATFORM_MERCHANT_ID=
PAYPAL_PARTNER_MERCHANT_ID=
PAYPAL_PLATFORM_PAYEE_EMAIL=
# Manual E2E only (not read by app code):
PAYPAL_SANDBOX_BUSINESS_EMAIL=
PAYPAL_SANDBOX_BUSINESS_PASSWORD=
PAYPAL_SANDBOX_BUYER_EMAIL=
PAYPAL_SANDBOX_BUYER_PASSWORD=
PAYPAL_SANDBOX_TEST_CARD_NUMBER=
PAYPAL_SANDBOX_TEST_CARD_EXP=
PAYPAL_SANDBOX_TEST_CARD_CVC=
PAYPAL_LIVE_PLATFORM_EMAIL=
PAYPAL_LIVE_PLATFORM_PASSWORD=

# ── AI Chat Widget ───────────────────────────────────────────────────
# LLM provider for the AI chat bubble (groq, openai, novita)
CHAT_LLM_PROVIDER=groq
CHAT_LLM_API_KEY=
CHAT_LLM_MODEL=openai/gpt-oss-20b
CHAT_MAX_RESPONSE_TOKENS=1024
CHAT_RATE_LIMIT=10

# Fallback provider (used when primary fails)
CHAT_FALLBACK_PROVIDER=
CHAT_FALLBACK_API_KEY=
CHAT_FALLBACK_MODEL=

# ── Bitcoin Deposits (On-Chain) ──────────────────────────────────────
# Requires a local Bitcoin Core node with JSON-RPC enabled.
# Set XCELSIOR_BTC_ENABLED=true to activate crypto deposits.
XCELSIOR_BTC_ENABLED=false
XCELSIOR_BTC_RPC_HOST=127.0.0.1
XCELSIOR_BTC_RPC_PORT=8332
XCELSIOR_BTC_RPC_USER=
XCELSIOR_BTC_RPC_PASS=
XCELSIOR_BTC_RPC_TIMEOUT=3
# Short status probe used by the billing page card. Lower keeps the UI snappy.
XCELSIOR_BTC_STATUS_RPC_TIMEOUT=1.5
# Optional comma-separated fallback hosts. Useful when the app may run either
# on the host or inside Docker and the same node is reachable on different names.
XCELSIOR_BTC_RPC_FALLBACK_HOSTS=
XCELSIOR_BTC_CONFIRMATIONS=3
XCELSIOR_BTC_DEPOSIT_EXPIRY=1800
XCELSIOR_BTC_AUTO_WALLET=xcelsior
XCELSIOR_BTC_RPC_WALLET=

# ── Lightning Network (CLN) ──────────────────────────────────────────
# Core Lightning REST endpoint for instant BTC deposits via Lightning invoices.
XCELSIOR_LN_ENABLED=false
XCELSIOR_LN_CLNREST_URL=
XCELSIOR_LN_RUNE=
XCELSIOR_LN_INVOICE_EXPIRY=600
XCELSIOR_LN_DB_PATH=xcelsior_ln.db
XCELSIOR_LN_MIN_CAD=1
XCELSIOR_LN_MAX_CAD=1000

# ── Slurm HPC Integration ───────────────────────────────────────────
XCELSIOR_SLURM_PROFILE=generic
XCELSIOR_SLURM_EMAIL=

# ── Frontend (Next.js) ───────────────────────────────────────────────
# These are build-time vars baked into the Next.js bundle.
NEXT_PUBLIC_API_URL=https://xcelsior.ca
NEXT_PUBLIC_APP_URL=https://xcelsior.ca
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_LIVE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_SANDBOX_PUBLISHABLE_KEY=
NEXT_PUBLIC_WS_URL=
NEXT_PUBLIC_SSH_HOST=connect.xcelsior.ca

# Google Analytics 4 — measurement ID (e.g. G-XXXXXXXXXX)
# Create at: https://analytics.google.com → Admin → Data Streams → Web
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-EPD8EJ9R5D

# Google Search Console — verification code (just the content value)
# Get from: https://search.google.com/search-console → Add property → HTML tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=Hi9iWjQOtkPCcVkL8wa4yLshmELHotjRYVw-oL7txcA

# ── Desktop (Tauri 2) ────────────────────────────────────────────────
# Signing keypair for auto-updater. Generate: npx tauri signer generate --ci
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=
TAURI_SIGNING_PUBLIC_KEY=

# ── Desktop / PWA Smoke Tests ────────────────────────────────────────
# Used by the authenticated desktop push smoke against a live environment.
XCELSIOR_PWA_SMOKE_BASE_URL=
XCELSIOR_PWA_SMOKE_EMAIL=
XCELSIOR_PWA_SMOKE_PASSWORD=
XCELSIOR_PWA_SMOKE_REQUIRE_CLICK=1
XCELSIOR_PWA_SMOKE_CLICK_TIMEOUT_MS=45000

# ── AI Assistant (Xcel AI) ───────────────────────────────────────────
# Feature flag — set to true to enable the AI chat assistant.
FEATURE_AI_ASSISTANT=false
# Live provider calls are disabled by default so you can test Xcel AI without spending.
AI_ASSISTANT_ENABLE_LIVE_CALLS=false
# Primary Xcel AI provider (xai, anthropic, openai)
AI_ASSISTANT_PROVIDER=xai
# Fallback order for Xcel AI. Providers without keys are skipped.
AI_ASSISTANT_FALLBACK_PROVIDERS=anthropic,openai
# Anthropic API key for Claude fallback / tool-capable mode. Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Anthropic model to use
AI_ASSISTANT_MODEL=claude-3-5-haiku-20241022
# xAI provider config
AI_ASSISTANT_XAI_API_KEY=
AI_ASSISTANT_XAI_MODEL=grok-4
# OpenAI provider config
AI_ASSISTANT_OPENAI_API_KEY=
AI_ASSISTANT_OPENAI_MODEL=gpt-4o-mini
# Max tokens per response
AI_ASSISTANT_MAX_TOKENS=4096
# Rate limit: max requests per user per minute
AI_ASSISTANT_RATE_LIMIT=20
# HMAC secret for signing AI action confirmations. Auto-generated if empty.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
AI_CONFIRMATION_SECRET=

# ── SDK Publishing (CI/CD) ───────────────────────────────────────────
# Fern token for generating & publishing the TypeScript SDK.
# Get from: https://app.buildwithfern.com → Settings → API Keys
FERN_TOKEN=
# npm access token with read+write on @xcelsior-gpu scope.
# Get from: https://www.npmjs.com → Access Tokens → Granular Access Token
NPM_TOKEN=

# ── SMS / Phone Verification (Twilio) ────────────────────────────────
# Get keys at: https://console.twilio.com
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# ── WebAuthn / Passkeys ──────────────────────────────────────────────
XCELSIOR_WEBAUTHN_RP_ID=xcelsior.ca
XCELSIOR_WEBAUTHN_ORIGIN=https://xcelsior.ca

# ── Auth Rate Limiting ───────────────────────────────────────────────
# Tighter rate limit specifically for auth endpoints (login, register, etc.)
XCELSIOR_AUTH_RATE_LIMIT_REQUESTS=10

# ── Secrets Encryption ───────────────────────────────────────────────
# Fernet key for encrypting secrets at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
XCELSIOR_SECRETS_KEY=

# ── Container Network Security ───────────────────────────────────────
# Bandwidth limit for GPU containers (Mbps)
XCELSIOR_CONTAINER_BW_MBPS=100

# ── Serverless Inference (feature-flagged GA) ────────────────────────
# Off by default in prod templates; set true for GA (empty allowlist = all owners).
XCELSIOR_SERVERLESS_ENABLED=false
# Comma-separated customer_id values (empty = all owners when globally enabled)
XCELSIOR_SERVERLESS_ALLOWLIST=
# Background autoscaler + reaper tick (api.py / bg_worker.py, every 45s)
XCELSIOR_SERVERLESS_RECONCILE=true
XCELSIOR_SERVERLESS_SCALE_DOWN_COOLDOWN_SEC=60
XCELSIOR_SERVERLESS_DRAIN_GRACE_SEC=30
XCELSIOR_SERVERLESS_JOB_HEARTBEAT_TTL_SEC=120
XCELSIOR_SERVERLESS_BOOTING_TTL_SEC=900
XCELSIOR_SERVERLESS_QUEUE_TTL_SEC=3600
XCELSIOR_SERVERLESS_MIN_BILLING_INTERVAL_SEC=60
XCELSIOR_SERVERLESS_WEBHOOK_MAX_ATTEMPTS=3
XCELSIOR_SERVERLESS_WEBHOOK_TIMEOUT_SEC=10
XCELSIOR_SERVERLESS_WEBHOOK_BACKOFF_BASE_SEC=5
XCELSIOR_SERVERLESS_WEBHOOK_MAX_BODY_BYTES=65536
# HMAC signing secret for job webhooks (defaults to scheduler API token)
XCELSIOR_SERVERLESS_WEBHOOK_HMAC_SECRET=
# Phase 15: optional Vast-style queue-depth forecasting (see serverless/scaling_predictive.py)
XCELSIOR_SERVERLESS_PREDICTIVE_SCALING=false
# Phase 15: Redis-backed per-key RPM (falls back to in-process when unset/disabled)
XCELSIOR_SERVERLESS_REDIS_RATE_LIMITS=false
XCELSIOR_SERVERLESS_REDIS_URL=
# Comma-separated peer regions for NFS model-cache replication (e.g. ca-west,ca-east)
XCELSIOR_SERVERLESS_CACHE_REPLICATE_REGIONS=

# ── Inference Pricing & Limits ───────────────────────────────────────
XCELSIOR_INFERENCE_MAX_TOKENS=2048
XCELSIOR_INFERENCE_TIMEOUT=120
XCELSIOR_INFERENCE_SCALEDOWN=300
XCELSIOR_INPUT_TOKEN_PRICE=0.50
XCELSIOR_OUTPUT_TOKEN_PRICE=1.50

# ── Worker Volume Storage ────────────────────────────────────────────
# Encrypted volume mount/key directories on GPU workers
XCELSIOR_VOLUME_DIR=/mnt/xcelsior/volumes
XCELSIOR_VOLUME_KEY_DIR=/etc/xcelsior/volume-keys

# ── NVMe Model Cache ─────────────────────────────────────────────────
# Local NVMe cache for model weights on GPU workers
XCELSIOR_NVME_CACHE_DIR=/mnt/nvme/model-cache
XCELSIOR_NVME_CACHE_MAX_GB=200

# ── Spot Pricing (Marketplace module) ────────────────────────────────
# These supplement the XCELSIOR_SPOT_* vars above (used in marketplace.py)
XCELSIOR_SPOT_K=0.5
XCELSIOR_SPOT_INTERVAL_SEC=600

# ── Cloudburst (Cloud Overflow) ──────────────────────────────────────
# Overflow queued GPU jobs to cloud providers when local capacity is full
XCELSIOR_BURST_ENABLED=false
XCELSIOR_BURST_BUDGET_CAD=500.0
XCELSIOR_BURST_MAX_INSTANCES=10
XCELSIOR_BURST_QUEUE_THRESHOLD=5
XCELSIOR_BURST_DRAIN_IDLE_SEC=900
# Provider priority — try cheapest first
XCELSIOR_BURST_PROVIDER_PRIORITY=hetzner,oci,gcp,aws
# AWS cloudburst config
XCELSIOR_BURST_AWS_AMI=
XCELSIOR_BURST_AWS_KEY_PAIR=
XCELSIOR_BURST_AWS_SECURITY_GROUP=
XCELSIOR_BURST_AWS_SUBNET=
# GCP cloudburst config
XCELSIOR_BURST_GCP_PROJECT=
XCELSIOR_BURST_GCP_ZONE=northamerica-northeast1-a
XCELSIOR_BURST_GCP_IMAGE_FAMILY=pytorch-latest-gpu
# OCI (Oracle Cloud — cheapest A10G)
XCELSIOR_BURST_OCI_TENANCY=
XCELSIOR_BURST_OCI_USER=
XCELSIOR_BURST_OCI_COMPARTMENT=
XCELSIOR_BURST_OCI_REGION=ca-toronto-1
XCELSIOR_BURST_OCI_SUBNET=
XCELSIOR_BURST_OCI_IMAGE=
# Hetzner Cloud (cheapest L4/A100 in EU)
XCELSIOR_BURST_HETZNER_TOKEN=
XCELSIOR_BURST_HETZNER_LOCATION=nbg1
XCELSIOR_BURST_HETZNER_SSH_KEY_NAME=
XCELSIOR_BURST_HETZNER_IMAGE=ubuntu-24.04

# ── Observability (Jaeger / OpenTelemetry) ───────────────────────────
# Self-hosted Jaeger receives traces via OTLP gRPC on :4317, UI on :16686
# docker compose brings up Jaeger automatically
OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4317

# ── Deployment ───────────────────────────────────────────────────────
XCELSIOR_DEPLOY_HOST=149.28.121.61
XCELSIOR_DEPLOY_USER=linuxuser
XCELSIOR_TARGET_ENV=prod
XCELSIOR_SSH_KEY=$HOME/.ssh/xcelsior
XCELSIOR_API_PORT=9500
XCELSIOR_API_BLUE_PORT=9501
XCELSIOR_FRONTEND_PORT=3000

# ── Backup / Restore ─────────────────────────────────────────────────
XCELSIOR_BACKUP_DIR=/var/backups/xcelsior
XCELSIOR_BACKUP_RETAIN_DAYS=14

# ── Container Registry (snapshot push/pull) ──────────────────────────
# P3/C6 + Phase E — canonical var used by worker_agent.snapshot_container
# and routes/instances._build_image_ref. Required in production. When
# blank, snapshot requests return status=failed (Phase E drops the old
# local-only fallback). Use a fully-qualified host + path prefix.
XCELSIOR_REGISTRY_URL=ghcr.io/aabiro
XCELSIOR_REGISTRY_USERNAME=aabiro
# Write the actual token only in .env (never .env.example). Prefer a PAT
# with write:packages + read:packages scopes for ghcr.io, or a Harbor
# robot account password.
XCELSIOR_REGISTRY_PASSWORD=
# GitHub PAT reused as registry password for ghcr.io deployments and by
# provisioning scripts for private repo clone when needed.
XCELSIOR_GITHUB_PAT=
# Legacy scheduler-side registry var. Only used by the old scheduler
# PUSH path (scheduler.py). For new code, use XCELSIOR_REGISTRY_URL.
XCELSIOR_REGISTRY=

# ── Cloudflare (xcelsior.ca DNS) ──────────────────────────────────────
# Scoped API token with DNS:Edit on the xcelsior.ca zone (store real value in .env only).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=765e9aaccef7b0d21a8b3c81cff9eb67
CLOUDFLARE_ACCOUNT_ID=edd0844d6404030c775c12e0ea7a67a5
